<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    tools:context=".SplashActivity">

    <ImageView
        android:id="@+id/intro_donoff_logo"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/height_logo"
        android:adjustViewBounds="true"
        android:src="@drawable/donoff"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.35" />

    <TextView
        android:id="@+id/intro_donoff"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_large"
        android:fontFamily="@font/notosans_kr_black"
        android:text="@string/app_name"
        android:textColor="@color/white"
        android:textSize="@dimen/text_title"
        app:layout_constraintEnd_toEndOf="@+id/intro_donoff_logo"
        app:layout_constraintStart_toStartOf="@+id/intro_donoff_logo"
        app:layout_constraintTop_toBottomOf="@+id/intro_donoff_logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/notosans_kr_regular"
        android:text="@string/app_subtitle"
        android:textColor="@color/white"
        android:textSize="@dimen/text_medium"
        app:layout_constraintEnd_toEndOf="@+id/intro_donoff"
        app:layout_constraintStart_toStartOf="@+id/intro_donoff"
        app:layout_constraintTop_toBottomOf="@+id/intro_donoff" />
</androidx.constraintlayout.widget.ConstraintLayout>