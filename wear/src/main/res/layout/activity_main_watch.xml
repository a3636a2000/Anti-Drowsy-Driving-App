<?xml version="1.0" encoding="utf-8"?>
<!--
    메인 화면
    - 진입 시 타이틀 위에서 슬라이드 + 콘텐츠 스케일 업
    - 심박수 수신마다 심장 박동 스케일 애니메이션
    - BPM 숫자는 ValueAnimator로 부드럽게 변경
    - 졸음 감지 시 flash_overlay가 노란색으로 반짝
    - 졸음 상태: 아이콘·텍스트 색상이 흰색→노란색으로 ArgbEvaluator 전환
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- 메인 콘텐츠 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_screen_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/screen_title"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            android:alpha="0"
            android:translationY="-20dp" />

        <!-- 심장 아이콘 + BPM 수치 -->
        <LinearLayout
            android:id="@+id/content_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:alpha="0"
            android:scaleX="0.6"
            android:scaleY="0.6">

            <ImageView
                android:id="@+id/iv_heart"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@drawable/ic_heart"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tv_bpm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="40sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="bottom"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tv_bpm_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bpm_unit"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- 졸음 경고 플래시 오버레이 (평소 alpha=0, 경고 시 반짝임) -->
    <View
        android:id="@+id/flash_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFCC00"
        android:alpha="0" />

</FrameLayout>
